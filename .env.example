# =============================================================================
#  Zahran Retail System — Environment Variables
#  انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل في الإنتاج.
#    cp .env.example .env
# =============================================================================

# ---- PostgreSQL ----
DB_NAME=zahran_retail
DB_USER=zahran
DB_PASS=change_me_strong_password_here
DB_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- MinIO (S3-compatible) ----
MINIO_USER=zahran
MINIO_PASS=change_me_strong_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=zahran-media

# ---- Backend API ----
API_PORT=3000
JWT_SECRET=please_change_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=12h
REFRESH_TOKEN_DAYS=14

# ---- Frontend ----
WEB_PORT=8080
VITE_API_URL=http://localhost:3000

# ---- Business settings (تُستخدم في seed/migrations) ----
TZ=Africa/Cairo
DEFAULT_CURRENCY=EGP
DEFAULT_WAREHOUSE_CODE=ZHR-01
DEFAULT_TAX_RATE=0

# ---- Email / SMS (اختياري) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER=
SMS_API_KEY=

# ---- Alerts ----
ALERT_LOW_STOCK_THRESHOLD=5
ALERT_CASH_MISMATCH_EGP=50

# ---- Offline sync ----
OFFLINE_SYNC_BATCH_SIZE=100
OFFLINE_MAX_RETRY=5
