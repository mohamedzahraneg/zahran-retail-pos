NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgres://zahran:change_me_strong@localhost:5432/zahran_retail
DB_LOGGING=false

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_KEY=zahran
S3_SECRET=change_me_strong
S3_BUCKET=zahran-media

# JWT
JWT_SECRET=please_change_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=12h
REFRESH_TOKEN_DAYS=14

# Business
TZ=Africa/Cairo
DEFAULT_CURRENCY=EGP
DEFAULT_WAREHOUSE_CODE=ZHR-01
DEFAULT_TAX_RATE=0

# Alerts
ALERT_LOW_STOCK_THRESHOLD=5
ALERT_CASH_MISMATCH_EGP=50

# Offline sync
OFFLINE_SYNC_BATCH_SIZE=100
OFFLINE_MAX_RETRY=5

# CORS
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
