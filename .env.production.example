# =============================================================================
#  Zahran Retail — PRODUCTION environment template
#
#  Copy this file to `.env` on the production VPS (/opt/zahran/.env) and
#  fill in the real values. This file is committed. The real `.env` is
#  gitignored and MUST NOT be committed.
#
#  Production source of truth:
#    - Database : Supabase PostgreSQL (single-tenant, region eu-central-2)
#    - URL      : https://pos.turathmasr.com
#    - VPS path : /opt/zahran
#    - Deploy   : scripts/deploy.sh  (rsync + docker compose --profile full up -d)
#
#  DO NOT point DATABASE_URL at the docker-compose `db:` service. That
#  service is now gated behind the `dev` profile and is never started in
#  production. See docs/DEPLOYMENT.md for the full rationale.
# =============================================================================

# -----------------------------------------------------------------------------
#  REQUIRED — Supabase Postgres pooler DSN
#
#  Shape:
#    postgres://postgres.<PROJECT_REF>:<PASSWORD>@aws-<REGION>.pooler.supabase.com:6543/postgres
#
#  Port 6543 = Supavisor transaction-mode pooler (correct for NestJS + pg).
#  Port 5432 = session-mode pooler — only use if you need session features.
#
#  Supabase project ref: teyjynfijgwdxusbdzgz
#  Never paste the password here; set it only in the VPS `.env`.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres.teyjynfijgwdxusbdzgz:__REPLACE_WITH_DB_PASSWORD__@aws-<REGION>.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
#  Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
TZ=Africa/Cairo

# -----------------------------------------------------------------------------
#  JWT — rotate before the first production cutover
# -----------------------------------------------------------------------------
JWT_SECRET=__REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS__
JWT_EXPIRES_IN=12h
REFRESH_TOKEN_DAYS=14

# -----------------------------------------------------------------------------
#  CORS — the public frontend origin(s)
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://pos.turathmasr.com

# -----------------------------------------------------------------------------
#  Redis + object storage — these stay inside the docker network
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
S3_KEY=__REPLACE__
S3_SECRET=__REPLACE__
S3_BUCKET=zahran-media

# -----------------------------------------------------------------------------
#  Business defaults
# -----------------------------------------------------------------------------
DEFAULT_CURRENCY=EGP
DEFAULT_WAREHOUSE_CODE=ZHR-01
DEFAULT_TAX_RATE=0

# -----------------------------------------------------------------------------
#  Alerts
# -----------------------------------------------------------------------------
ALERT_LOW_STOCK_THRESHOLD=5
ALERT_CASH_MISMATCH_EGP=50
